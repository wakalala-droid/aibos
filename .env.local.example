# ─── AI-BOS Environment Variables ───────────────────────────────────────────
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# SERVER ONLY — never prefix with NEXT_PUBLIC_ and never expose to the browser.
# This is the `service_role` key (Supabase → Project Settings → API → Project API
# keys → service_role). It bypasses RLS and is used only by app/api/admin/* to
# perform admin-verified, cross-account writes. NOTE: this is NOT the anon key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Admin allowlist ─────────────────────────────────────────────────────────────
# Comma-separated emails that bootstrap admin access (works before any
# profiles.role='admin' row exists). Server only.
ADMIN_EMAILS=vwanheda@gmail.com

# ── FastAPI Backend ────────────────────────────────────────────────────────────
# Your Railway/Render deployment URL
NEXT_PUBLIC_API_URL=https://your-api.railway.app

# ── App URL ────────────────────────────────────────────────────────────────────
# Your Vercel deployment URL (or localhost for dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE GOOGLE OAUTH SETUP CHECKLIST:
#
# 1. Go to Supabase Dashboard → Authentication → Providers → Google
# 2. Enable Google provider
# 3. Add your Google Cloud OAuth Client ID and Secret
# 4. Set the Redirect URL in Google Cloud Console to:
#    https://your-project.supabase.co/auth/v1/callback
# 5. Add your app URL to Supabase's "Site URL" setting
# 6. Add redirect URLs to Supabase "Redirect URLs" (Additional Redirect URLs):
#    http://localhost:3000/auth/callback
#    https://your-app.vercel.app/auth/callback
# ─────────────────────────────────────────────────────────────────────────────
